# NEXT_PUBLIC_ ile baslayan degiskenler frontend bundle icinde herkese acik olur.
# Gizli token, API key, admin sifresi veya secret degerlerini NEXT_PUBLIC_ ile kullanmayin.
# Development:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Production:
NEXT_PUBLIC_API_URL=https://dijital-iz-avcisi-api.onrender.com

# Server-side / hosting env ornekleri. Gercek degerleri GitHub'a koymayin.
ADMIN_ALLOWED_IPS=
AUTH_SECRET=change-me-on-hosting
CRON_SECRET=
OPENAI_API_KEY=
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=iletisim@dijitalizavcisi.com
SMTP_PASS=
CONTACT_TO_EMAIL=iletisim@dijitalizavcisi.com
CONTACT_FROM_EMAIL=iletisim@dijitalizavcisi.com
DATABASE_URL=

# Siber haberler icin Supabase REST kullaniliyorsa sadece server-side env olarak tanimlayin.
# Service role key tarayiciya gonderilmemeli ve NEXT_PUBLIC_ prefix'i almamalidir.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
